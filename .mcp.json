{
  "mcpServers": {
    "context7": {
      "command": "cmd",
      "args": [
        "/c",
        "npx",
        "-y",
        "@upstash/context7-mcp"
      ],
      "env": {
        "EXA_API_KEY": "$CONTEXT7_API_KEY"
      }
    },
    "exa": {
      "command": "cmd",
      "args": [
        "/c",
        "npx",
        "exa-mcp-server",
        "tools=web_search_exa,get_code_context_exa,crawling_exa,deep_researcher_start,deep_researcher_check"
      ],
      "env": {
        "EXA_API_KEY": "${EXA_API_KEY}"
      }
    },
    "shadcn": {
      "command": "cmd ",
      "args": [
        "/c",
        "npx",
        "shadcn@latest",
        "mcp"
      ],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_PERSONAL_ACCESS_TOKEN}"
      }
    },
    "cloudflare-graphql": {
      "command": "cmd",
      "args": [
        "/c",
        "npx",
        "-y",
        "mcp-remote",
        "https://graphql.mcp.cloudflare.com/mcp",
        "--header",
        "Authorization: Bearer ${CLOUDFLARE_API_TOKEN}"
      ]
    },
    "cloudflare-auditlogs": {
      "command": "cmd",
      "args": [
        "/c",
        "npx",
        "-y",
        "mcp-remote",
        "https://auditlogs.mcp.cloudflare.com/mcp"
      ],
      "headers": {
        "Authorization": "Bearer ${CLOUDFLARE_API_TOKEN}"
      }
    },
    "cloudflare-dns-analytics": {
      "command": "cmd",
      "args": [
        "/c",
        "npx",
        "-y",
        "mcp-remote",
        "https://dns.analytics.mcp.cloudflare.com/mcp"
      ]
    },
    "cloudflare-logs": {
      "command": "cmd",
      "args": [
        "/c",
        "npx",
        "-y",
        "mcp-remote",
        "https://logs.mcp.cloudflare.com/mcp"
      ],
      "headers": {
        "Authorization": "Bearer ${CLOUDFLARE_API_TOKEN}"
      }
    },
    "cloudflare-radar": {
      "command": "cmd",
      "args": [
        "/c",
        "npx",
        "-y",
        "mcp-remote",
        "https://radar.mcp.cloudflare.com/mcp"
      ],
      "headers": {
        "Authorization": "Bearer ${CLOUDFLARE_API_TOKEN}"
      }
    },
        "cloudflare-bindings": {
      "command": "cmd",
      "args": [
        "/c",
        "npx",
        "-y",
        "mcp-remote",
        "https://bindings.mcp.cloudflare.com/mcp"
      ],
      "headers": {
        "Authorization": "Bearer ${CLOUDFLARE_API_TOKEN}"
      }
    },
  "workers-bindings": {
    "command": "cmd",
    "args": [
      "/c",
      "npx",
      "-y",
      "mcp-remote",
      "https://bindings.mcp.cloudflare.com/mcp"
    ],
    "headers": {
      "Authorization": "Bearer ${CLOUDFLARE_API_TOKEN}"
    }
  },
  "cloudflare-observability": {
    "command": "cmd",
    "args": [
      "/c",
      "npx",
      "-y",
      "mcp-remote",
      "https://observability.mcp.cloudflare.com/mcp"
    ],
    "headers": {
      "Authorization": "Bearer ${CLOUDFLARE_API_TOKEN}"
    }}

  }
}